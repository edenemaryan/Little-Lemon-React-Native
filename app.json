{
  "expo": {
    "name": "LittleLemonMobile",
    "slug": "LittleLemonMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/little-lemon-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/little-lemon-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#EDEFEE"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/little-lemon-logo.png",
        "backgroundColor": "#EDEFEE"
      }
    },
    "web": {
      "favicon": "./assets/images/little-lemon-logo.png"
    },
    "plugins": [
      "expo-sqlite"
    ]
  }
}
